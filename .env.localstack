# Environment variables for Lambda containers running in LocalStack.
# host.docker.internal resolves to the Docker host, where Postgres/Qdrant/etc run.
# API keys are injected at deploy time from the host environment.

S3_ENDPOINT_URL=http://host.docker.internal:4566
S3_BUCKET_NAME=agensus
S3_REGION=us-east-1

SQS_ENDPOINT_URL=http://host.docker.internal:4566
SQS_QUEUE_URL=__SQS_QUEUE_URL__
SQS_REGION=us-east-1

POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=dms_db

QDRANT_HOST=host.docker.internal
QDRANT_PORT=6333
QDRANT_COLLECTION=document_chunks

VOYAGEAI_API_KEY=__VOYAGEAI_API_KEY__
VOYAGEAI_MODEL=voyage-3

OPENAI_API_KEY=__OPENAI_API_KEY__
OPENAI_MODEL=gpt-4o-mini

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
